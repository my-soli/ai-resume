# Application
APP_NAME=Resume AI
APP_VERSION=1.0.0
DEBUG=true

# Database
DATABASE_URL=postgresql://resumeai:resumeai_password@localhost:5432/resumeai_db

# JWT Security
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Storage (local or s3)
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./storage

# S3 (only needed if STORAGE_TYPE=s3)
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Rate Limiting
AI_RATE_LIMIT=10/minute
