# Copy this to .env and fill in your values

APP_NAME=Resume AI
APP_VERSION=1.0.0
DEBUG=false

# Database (auto-configured in docker-compose)
DATABASE_URL=postgresql://resumeai:resumeai_password@db:5432/resumeai_db

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Storage
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./storage

# S3 (set STORAGE_TYPE=s3 and fill these to use S3)
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Rate Limiting
AI_RATE_LIMIT=10/minute
